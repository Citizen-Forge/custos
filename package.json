{
  "name": "custos",
  "version": "0.1.0",
  "description": "Anthropic-format LLM proxy with permission gating and semantic memory for Claude Code",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "login": "tsx src/auth/login-cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.1.0",
    "undici": "^7.2.0",
    "@qdrant/js-client-rest": "^1.13.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
