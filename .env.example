# Optional: enables the Anthropic provider's API-key fallback path when the
# OAuth session is unavailable or rejected. Not required to run OAuth-only.
ANTHROPIC_API_KEY=

# Optional: host directory to bind-mount at /workspace for remote-control
# sessions. Defaults to an empty local ./workspace if unset.
CUSTOS_WORKSPACE=

# Optional: sets the admin/remote-control login password on first boot. If
# unset, a random one is generated and printed to the container logs once.
# Ignored on subsequent boots once data/auth.json exists -- change the
# password from the admin UI after that instead.
ADMIN_PASSWORD=
